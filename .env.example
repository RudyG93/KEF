# ── Resend (formulaire de contact) ───────────────────────────────
# Clé API Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Destinataire des demandes de devis (adresse de réception).
# Obligatoire : sans cette variable, le formulaire renvoie une erreur.
CONTACT_TO_EMAIL=destinataire@exemple.fr

# Expéditeur. Tant qu'aucun domaine n'est vérifié dans Resend, on utilise
# le domaine de test "onboarding@resend.dev" (n'envoie que vers l'e-mail
# du compte Resend). Une fois le domaine vérifié : "KEF <contact@ton-domaine.fr>".
CONTACT_FROM_EMAIL="KEF <onboarding@resend.dev>"
